# ==========================================
# Production Dockerfile for Background Worker
# Runs email, report, and WhatsApp queue workers
# Complies with DEP-01 & ARCH-SERVER-04
# ==========================================

# ------------------------------------------
# Stage 1: Dependencies
# ------------------------------------------
# Stage 1: Dependencies
# ------------------------------------------
FROM oven/bun:alpine AS deps
RUN apk add --no-cache libc6-compat
WORKDIR /app

# Copy package configurations
COPY package.json bun.lock ./

# Install ONLY production dependencies using Bun to minimize size
RUN bun install --frozen-lockfile --production --ignore-scripts

# ------------------------------------------
# Stage 2: Runner
# ------------------------------------------
FROM node:20-alpine AS runner
# Copy Bun from official image
COPY --from=oven/bun:alpine /usr/local/bin/bun /usr/local/bin/bun
RUN apk add --no-cache libc6-compat openssl && bun add -g prisma
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Security: Don't run as root
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 worker

# Copy dependencies and pruned node_modules
COPY --from=deps --chown=worker:nodejs /app/node_modules ./node_modules
COPY --chown=worker:nodejs package.json ./
COPY --chown=worker:nodejs tsconfig.json ./
COPY --chown=worker:nodejs prisma.config.ts ./
COPY --chown=worker:nodejs prisma ./prisma
COPY --chown=worker:nodejs src ./src

# Generate Prisma client via dummy url (bypasses runtime requirement during build)
RUN DATABASE_URL=mysql://localhost:3306/dummy npx prisma generate

USER worker

# Execute worker script directly via bun
CMD ["bun", "run", "src/worker.ts"]
