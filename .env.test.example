# =============================================================================
# .env.test.example — Copy to .env.test for local runtime verification.
# =============================================================================
# Used by scripts/smoke/*.ts and tests/e2e/*.test.ts. All values point at
# sandbox-local services started by scripts/smoke/up.sh:
#   - MariaDB on 127.0.0.1:3306, schema "eitdc_test", user "eitdc"/"eitdc_pw"
#   - Redis on 127.0.0.1:6379
#   - Mailpit SMTP on 127.0.0.1:1025, HTTP API on 127.0.0.1:8025
# Nothing in this file should ever match a production credential.
# =============================================================================

DATABASE_URL=mysql://eitdc:eitdc_pw@127.0.0.1:3306/eitdc_test
REDIS_URL=redis://127.0.0.1:6379

AUTH_TRUST_HOST=true
NEXTAUTH_SECRET=test-secret-please-do-not-use-in-prod-0123456789abcdef0123456789abcdef
NEXTAUTH_URL=http://127.0.0.1:3000

NEXT_PUBLIC_APP_NAME="EITDC Test Harness"
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=test
SMTP_PASS=test
EMAIL_FROM=ebic-noreply@cit.edu.ly
EMAIL_FROM_NAME="EITDC Verification"
EMAIL_REPLY_TO=ebic@cit.edu.ly
EMAIL_TOKEN_SECRET=test-email-token-secret

TWO_FACTOR_ENABLED=true
TWO_FACTOR_CODE_TTL_SECONDS=600
TWO_FACTOR_MAX_ATTEMPTS=5
TWO_FACTOR_RESEND_COOLDOWN_SECONDS=60

# WhatsApp — leave empty so the UltraMsg transport stays in mock mode
WHATSAPP_API_TOKEN=
WHATSAPP_API_URL=
WHATSAPP_SENDER_NUMBER=+218000000000

SMOKE_TEST_INBOX=smoke@eitdc.test

ALLOWED_ORIGINS=http://127.0.0.1:3000
ADMIN_API_KEY=test-admin-api-key-only
INIT_ADMIN_EMAIL=admin@eitdc.test
INIT_ADMIN_PASSWORD=test-admin-pw-not-used

AWS_ACCESS_KEY_ID=
AWS_REGION=us-east-1
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_ENDPOINT=
S3_PUBLIC_ACCESS=false
CDN_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

NODE_ENV=test
