# ===========================================================
# EBIC Website - COMPLETE Production Environment Template
# ===========================================================
# This file contains EVERY environment variable referenced
# in the codebase. Copy to .env and fill in all CHANGE_ME values.
# NEVER commit .env to version control.
# ===========================================================
# Generated from: exhaustive grep of process.env.* across src/, prisma/, and config files.
# Date: 2026-02-19
# ===========================================================

# -----------------------------------------------------------
# 1. DATABASE
# -----------------------------------------------------------
DATABASE_URL=CHANGE_ME
# Example: mysql://user:password@host:3306/citcoder_eitdc
MYSQL_ROOT_PASSWORD=CHANGE_ME
MYSQL_DATABASE=citcoder_eitdc

# -----------------------------------------------------------
# 2. AUTHENTICATION (NextAuth.js v5)
# -----------------------------------------------------------
NEXTAUTH_SECRET=CHANGE_ME
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
NEXTAUTH_URL=CHANGE_ME
# Example: https://ebic.cit.edu.ly

# NextAuth v5 aliases (required)
AUTH_SECRET=${NEXTAUTH_SECRET}
AUTH_URL=${NEXTAUTH_URL}
AUTH_TRUST_HOST=true
# CRITICAL: Must be true when running behind a reverse proxy / load balancer

# -----------------------------------------------------------
# 3. APPLICATION
# -----------------------------------------------------------
NEXT_PUBLIC_APP_NAME=CHANGE_ME
# Example: Misurata Entrepreneurship Center
NEXT_PUBLIC_APP_URL=CHANGE_ME
# Example: https://ebic.cit.edu.ly
# CRITICAL: Used by RPC client, email templates, and login actions.

# -----------------------------------------------------------
# 4. ADMIN / SEEDING
# -----------------------------------------------------------
INIT_ADMIN_EMAIL=CHANGE_ME
INIT_ADMIN_PASSWORD=CHANGE_ME
# Used by prisma/seed.ts to create the initial admin user.
ADMIN_API_KEY=CHANGE_ME
# Used for Super Admin bypass / System tasks

# -----------------------------------------------------------
# 5. EMAIL (SMTP via Nodemailer)
# -----------------------------------------------------------
SMTP_HOST=CHANGE_ME
# Example: smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
# Set to "true" for port 465, "false" for port 587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
EMAIL_FROM=CHANGE_ME
# Example: ebic@cit.edu.ly
EMAIL_TOKEN_SECRET=CHANGE_ME
# Generate with: openssl rand -hex 32

# -----------------------------------------------------------
# 6. S3 / OBJECT STORAGE (MinIO or AWS S3)
# -----------------------------------------------------------
AWS_REGION=CHANGE_ME
# Example: us-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
S3_BUCKET_NAME=CHANGE_ME
# Example: ebic-media
S3_ENDPOINT=
# Leave empty for AWS S3. For MinIO: http://minio-host:9000
S3_PUBLIC_ACCESS=true
CDN_URL=
# Optional: CloudFront/Cloudflare CDN URL for public files

# -----------------------------------------------------------
# 7. REDIS
# -----------------------------------------------------------
REDIS_URL=CHANGE_ME
# Example: redis://localhost:6379
# CRITICAL: Required in production (fail-fast enabled).
REDIS_HOST=CHANGE_ME
REDIS_PORT=CHANGE_ME

# -----------------------------------------------------------
# 8. OAUTH PROVIDERS
# -----------------------------------------------------------
# Google OAuth (required for "Sign in with Google" button)
# Setup: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://YOUR_DOMAIN/api/auth/callback/google
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------
# 9. WHATSAPP INTEGRATION (UltraMsg)
# -----------------------------------------------------------
# Provider: UltraMsg (https://ultramsg.com) — 1000 free msgs/month
# Setup:
#   1. Sign up at ultramsg.com
#   2. Create an instance, scan the QR code with your WhatsApp
#   3. Go to Settings → copy Instance ID and Token
WHATSAPP_API_TOKEN=CHANGE_ME
WHATSAPP_API_URL=https://api.ultramsg.com/CHANGE_YOUR_INSTANCE_ID
WHATSAPP_SENDER_NUMBER=CHANGE_ME

# -----------------------------------------------------------
# 10. SECURITY / CORS
# -----------------------------------------------------------
ALLOWED_ORIGINS=CHANGE_ME
# Comma-separated. Example: https://ebic.cit.edu.ly,https://www.cit.edu.ly

# -----------------------------------------------------------
# 11. PUBLIC CONTACT INFO
# -----------------------------------------------------------
NEXT_PUBLIC_CONTACT_EMAIL=CHANGE_ME
NEXT_PUBLIC_CONTACT_PHONE=CHANGE_ME
NEXT_PUBLIC_CONTACT_LOCATION=CHANGE_ME
NEXT_PUBLIC_WORKING_HOURS=CHANGE_ME
NEXT_PUBLIC_MAP_EMBED_URL=CHANGE_ME

# -----------------------------------------------------------
# 12. THRESHOLDS
# -----------------------------------------------------------
NEXT_PUBLIC_INNOVATORS_THRESHOLD=3
NEXT_PUBLIC_COLLABORATORS_THRESHOLD=3
NEXT_PUBLIC_FAQ_THRESHOLD=1

# -----------------------------------------------------------
# 13. TESTING (development only, DO NOT set in production)
# -----------------------------------------------------------
# TEST_EMAIL=test@example.com
