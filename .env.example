# ===============================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# ===============================================
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# ===============================================

# 1. DATABASE CONFIGURATION
# Standard format: mysql://user:password@host:port/dbname
DATABASE_URL=mysql://<DB_USER>:<DB_PASS>@<DB_HOST>:<DB_PORT>/<DB_NAME>
# IMPORTANT FOR PRODUCTION:
# On shared hosting or serverless, add ?connection_limit=10 to the URL to prevent "too many connections" errors.
# Example: mysql://user:pass@host:3306/db?connection_limit=10

# 2. REDIS CONFIGURATION (Caching & Rate Limiting)
REDIS_URL=redis://<REDIS_HOST>:<REDIS_PORT>
# If REDIS_URL is omitted, the app will automatically fallback to in-memory (LRU) storage.
# Background workers (WhatsApp/Email queues) require a valid Redis connection.

# 3. AUTHENTICATION (NextAuth.js v5)
AUTH_TRUST_HOST=true
NEXTAUTH_SECRET=<REPLACE_WITH_SECRET>
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
NEXTAUTH_URL=http://localhost:3000

# 4. APPLICATION SETTINGS
NEXT_PUBLIC_APP_NAME="Misurata Entrepreneurship Center"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 5. ADMIN CONFIGURATION
ADMIN_API_KEY=<REPLACE_WITH_SECRET>
INIT_ADMIN_EMAIL=<ADMIN_EMAIL>
INIT_ADMIN_PASSWORD=<REPLACE_WITH_SECRET>

# 6. EMAIL SYSTEM (SMTP via Nodemailer)
EMAIL_FROM=<EMAIL_FROM>
EMAIL_TOKEN_SECRET=<REPLACE_WITH_SECRET>
SMTP_HOST=smtp.gmail.com
SMTP_PASS=<REPLACE_WITH_SECRET>
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=<SMTP_USER>

# 7. S3 STORAGE (MinIO for Dev / AWS S3 or R2 for Prod)
AWS_ACCESS_KEY_ID=<YOUR_AWS_ACCESS_KEY_ID>
AWS_REGION=<YOUR_AWS_REGION>
AWS_SECRET_ACCESS_KEY=<YOUR_AWS_SECRET_ACCESS_KEY>
S3_BUCKET_NAME=<S3_BUCKET_NAME>
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ACCESS=false
CDN_URL=

# 8. OAUTH PROVIDERS
GOOGLE_CLIENT_ID=<REPLACE_WITH_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<REPLACE_WITH_CLIENT_SECRET>
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# 9. WhatsApp (UltraMsg)
WHATSAPP_API_TOKEN=<REPLACE_WITH_TOKEN>
WHATSAPP_API_URL=<REPLACE_WITH_INSTANCE_URL>
WHATSAPP_SENDER_NUMBER=<REPLACE_WITH_NUMBER>

# 10. SECURITY / CORS
ALLOWED_ORIGINS=http://localhost:3000

# 11. PUBLIC CONTACT INFO
NEXT_PUBLIC_CONTACT_EMAIL=ebic@cit.edu.ly
NEXT_PUBLIC_CONTACT_PHONE=+218 91 000 0000
NEXT_PUBLIC_CONTACT_LOCATION=Misurata, Libya
NEXT_PUBLIC_WORKING_HOURS=Sun-Thu, 8am-3pm
NEXT_PUBLIC_MAP_EMBED_URL=

# 12. SOCIAL MEDIA LINKS
NEXT_PUBLIC_SOCIAL_FACEBOOK=
NEXT_PUBLIC_SOCIAL_TWITTER=
NEXT_PUBLIC_SOCIAL_LINKEDIN=
NEXT_PUBLIC_SOCIAL_WHATSAPP=

# 13. THRESHOLDS
NEXT_PUBLIC_INNOVATORS_THRESHOLD=3
NEXT_PUBLIC_COLLABORATORS_THRESHOLD=3
NEXT_PUBLIC_FAQ_THRESHOLD=1
