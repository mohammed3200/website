# ===========================================================
# EBIC Website — Production Environment Configuration
# ===========================================================
# Server: ebic.cit.edu.ly (102.213.182.106)
# Generated: 2026-04-20
# ===========================================================
# INSTRUCTIONS:
#   1. Replace all CHANGE_ME values with real credentials
#   2. Generate secrets with the commands shown in comments
#   3. Save as /opt/ebic/.env on the production server
#   4. NEVER commit this file to version control
# ===========================================================

# -----------------------------------------------------------
# 1. DATABASE (Docker-internal MySQL)
# -----------------------------------------------------------
DATABASE_URL=mysql://root:CHANGE_ME_DB_PASSWORD@db:3306/citcoder_eitdc?connection_limit=5
MYSQL_ROOT_PASSWORD=CHANGE_ME_DB_PASSWORD
MYSQL_DATABASE=citcoder_eitdc

# -----------------------------------------------------------
# 2. AUTHENTICATION (NextAuth.js v5)
# -----------------------------------------------------------
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
NEXTAUTH_URL=https://ebic.cit.edu.ly

# NextAuth v5 aliases (required — must match above)
AUTH_SECRET=${NEXTAUTH_SECRET}
AUTH_URL=${NEXTAUTH_URL}
AUTH_TRUST_HOST=true

# -----------------------------------------------------------
# 3. APPLICATION
# -----------------------------------------------------------
NEXT_PUBLIC_APP_NAME=مركز ريادة الأعمال والابتكار
NEXT_PUBLIC_APP_URL=https://ebic.cit.edu.ly

# -----------------------------------------------------------
# 4. ADMIN / SEEDING (first deploy only)
# -----------------------------------------------------------
INIT_ADMIN_EMAIL=CHANGE_ME@cit.edu.ly
INIT_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# Generate with: openssl rand -hex 24
ADMIN_API_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL

# -----------------------------------------------------------
# 5. EMAIL (SMTP)
# -----------------------------------------------------------
# For Gmail: enable "App Passwords" in Google Account security
# For institutional: use your university SMTP server
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=CHANGE_ME@cit.edu.ly
SMTP_PASS=CHANGE_ME_APP_PASSWORD
EMAIL_FROM=EBIC <CHANGE_ME@cit.edu.ly>
# Generate with: openssl rand -hex 32
EMAIL_TOKEN_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# -----------------------------------------------------------
# 6. S3 / OBJECT STORAGE (Docker-internal MinIO)
# -----------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME_MINIO_USER
AWS_SECRET_ACCESS_KEY=CHANGE_ME_MINIO_PASSWORD
S3_BUCKET_NAME=ebic-media
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ACCESS=true
CDN_URL=

# MinIO admin credentials (used by minio container)
MINIO_ROOT_USER=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD

# -----------------------------------------------------------
# 7. REDIS (Docker-internal)
# -----------------------------------------------------------
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# -----------------------------------------------------------
# 8. OAUTH PROVIDERS
# -----------------------------------------------------------
# Google OAuth — Follow setup guide in DEPLOYMENT.md
# Authorized redirect URI: https://ebic.cit.edu.ly/api/auth/callback/google
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME

# GitHub OAuth (optional — leave empty to disable)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------
# 9. WHATSAPP INTEGRATION (UltraMsg — optional)
# -----------------------------------------------------------
# Setup: https://ultramsg.com → Create instance → Scan QR
WHATSAPP_API_TOKEN=
WHATSAPP_API_URL=
WHATSAPP_SENDER_NUMBER=

# -----------------------------------------------------------
# 10. SECURITY / CORS
# -----------------------------------------------------------
ALLOWED_ORIGINS=https://ebic.cit.edu.ly

# -----------------------------------------------------------
# 11. PUBLIC CONTACT INFO
# -----------------------------------------------------------
NEXT_PUBLIC_CONTACT_EMAIL=CHANGE_ME@cit.edu.ly
NEXT_PUBLIC_CONTACT_PHONE=CHANGE_ME
NEXT_PUBLIC_CONTACT_LOCATION=CHANGE_ME
NEXT_PUBLIC_WORKING_HOURS=الأحد - الخميس: 8:00 ص - 4:00 م
NEXT_PUBLIC_MAP_EMBED_URL=CHANGE_ME

# -----------------------------------------------------------
# 12. THRESHOLDS
# -----------------------------------------------------------
NEXT_PUBLIC_INNOVATORS_THRESHOLD=3
NEXT_PUBLIC_COLLABORATORS_THRESHOLD=3
NEXT_PUBLIC_FAQ_THRESHOLD=1

# -----------------------------------------------------------
# 13. DOCKER ENTRYPOINT FLAGS
# -----------------------------------------------------------
# Set to "true" on FIRST deploy only, then remove or set to "false"
RUN_MIGRATIONS=true
RUN_SEEDS=true

# -----------------------------------------------------------
# 14. SOCIAL MEDIA LINKS (optional)
# -----------------------------------------------------------
NEXT_PUBLIC_SOCIAL_FACEBOOK=
NEXT_PUBLIC_SOCIAL_TWITTER=
NEXT_PUBLIC_SOCIAL_INSTAGRAM=
NEXT_PUBLIC_SOCIAL_LINKEDIN=
NEXT_PUBLIC_SOCIAL_YOUTUBE=
